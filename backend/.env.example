# GroundTruth Configuration
# Copy this to .env and fill in your values

# REQUIRED: Gemini API Key (get from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: Google Cloud
GOOGLE_CLOUD_PROJECT=your-project-id
GCS_BUCKET_NAME=
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Server
HOST=0.0.0.0
PORT=8080
DEBUG=False

# Document Processing
CHUNK_SIZE=500
CHUNK_OVERLAP=100
MAX_DOCUMENTS=50
MAX_RETRIEVAL_CHUNKS=5

# Voice (Kore, Puck, Charon, Fenrir, Aoede, Leda, Orus, Zephyr)
VOICE_NAME=Kore

# Security
MAX_QUERY_LENGTH=5000
RATE_LIMIT_RPM=30
# Set a strong random string to require X-API-Key header on all API routes.
# Leave empty to disable auth (development only).
API_KEY=
MAX_WS_MESSAGE_BYTES=10485760
